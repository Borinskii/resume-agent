# LLM provider: "auto" (Ollama then Fireworks), "ollama", or "fireworks".
LLM_PROVIDER=auto

# Local Ollama. https://ollama.com/download
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b

# Hosted Fireworks. https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v3p1

# GitHub PAT with `public_repo`. https://github.com/settings/tokens
GITHUB_TOKEN=

# Fernet key. Auto-generated on first run if empty.
CV_ENCRYPTION_KEY=

# Extra ATS boards. Format: "company:token,company:token".
EXTRA_GREENHOUSE_BOARDS=
EXTRA_LEVER_BOARDS=

# Session cookie secret. Auto-generated if empty.
SESSION_SECRET=
