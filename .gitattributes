# Normalize line endings: store everything as LF in the repo, regardless of OS.
# This silences the "LF will be replaced by CRLF" warnings and keeps diffs clean
# across Windows / macOS / Linux and the Ubuntu CI runner.
* text=auto eol=lf

# Explicit text files (belt and suspenders).
*.py     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
.env.example text eol=lf

# Binary files: never touch line endings.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.docx   binary
*.xlsx   binary
*.sqlite binary
*.zip    binary
